# Required
OPENAI_API_KEY=replace_me
SECRET_KEY=replace_me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,local
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8010
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stripe Billing
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_MONTHLY=price_replace_me_monthly
STRIPE_PRICE_YEARLY=price_replace_me_yearly
STRIPE_PRICE_SINGLE_MONTH=price_replace_me_single_month
STRIPE_PRICE_TRIAL_WEEK=price_replace_me_trial_week

# Celery / Redis (optional overrides)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Email / account recovery
# Default dev behavior writes emails to .local_mail/ so sign-in codes and reset links
# are available even when Docker/SMTP are not running.
# SITE_DOMAIN=127.0.0.1:8010
# SITE_NAME=AI Novel Creator
# EMAIL_BACKEND=django.core.mail.backends.filebased.EmailBackend
# EMAIL_FILE_PATH=.local_mail
# DEFAULT_FROM_EMAIL=AI Novel Creator <noreply@local.test>
# SERVER_EMAIL=AI Novel Creator <noreply@local.test>
# CONTACT_EMAIL=support@local.test
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=http

# Local development with Mailpit:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=127.0.0.1
# EMAIL_PORT=1025
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL=AI Novel Creator <noreply@local.test>
# SERVER_EMAIL=AI Novel Creator <noreply@local.test>
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=http

# Production SMTP example:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=replace_me
# EMAIL_HOST_PASSWORD=replace_me
# DEFAULT_FROM_EMAIL=AI Novel Creator <noreply@example.com>
# SERVER_EMAIL=AI Novel Creator <noreply@example.com>
# CONTACT_EMAIL=support@example.com
# ACCOUNT_DEFAULT_HTTP_PROTOCOL=https
# DEBUG=False
# ALLOWED_HOSTS=your-app.herokuapp.com
# CSRF_TRUSTED_ORIGINS=https://your-app.herokuapp.com
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=3600
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SECURE_CONTENT_TYPE_NOSNIFF=True
# X_FRAME_OPTIONS=DENY
# SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
# SESSION_COOKIE_HTTPONLY=True
# SESSION_COOKIE_SAMESITE=Lax
# CSRF_COOKIE_SAMESITE=Lax
# CONTACT_RATE_LIMIT=20
# CONTACT_RATE_WINDOW_SECONDS=3600
# CONTACT_SPIKE_ALERT_THRESHOLD=100
# PROJECT_404_ALERT_THRESHOLD=25
# WEBHOOK_SIGNATURE_ALERT_THRESHOLD=20

# Optional S3 media storage (production)
# USE_S3_MEDIA=False
# AWS_ACCESS_KEY_ID=replace_me
# AWS_SECRET_ACCESS_KEY=replace_me
# AWS_STORAGE_BUCKET_NAME=replace_me
# AWS_S3_REGION_NAME=eu-west-2
# AWS_S3_CUSTOM_DOMAIN=
# AWS_QUERYSTRING_AUTH=True

# Windows (Celery doesn't support prefork on Windows)
# CELERY_WORKER_POOL=solo
